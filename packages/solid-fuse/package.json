{
  "name": "solid-fuse",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./config": {
      "import": "./dist/config.js",
      "types": "./dist/config.d.ts"
    },
    "./icons/material": {
      "import": "./dist/icons/material.js",
      "types": "./dist/icons/material.d.ts"
    },
    "./icons/cupertino": {
      "import": "./dist/icons/cupertino.js",
      "types": "./dist/icons/cupertino.d.ts"
    }
  },
  "sideEffects": true,
  "bin": {
    "fuse": "./cli/index.ts"
  },
  "files": [
    "dist",
    "dart",
    "cli",
    "fuse.config.ts"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json && bun scripts/post-build.ts",
    "test": "bun test"
  },
  "peerDependencies": {
    "solid-js": "2.0.0-beta.7"
  },
  "dependencies": {
    "@solidjs/universal": "2.0.0-beta.7",
    "citty": "^0.1.6",
    "defu": "^6.1.6",
    "vite": "^8.0.0",
    "vite-plugin-solid": "^3.0.0-next.5"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "solid-js": "2.0.0-beta.7",
    "typescript": "^5.9.3"
  }
}
