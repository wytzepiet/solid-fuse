{
  "name": "solid-fuse",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "sideEffects": true,
  "bin": {
    "fuse": "./cli/index.ts"
  },
  "files": [
    "dist",
    "dart",
    "cli"
  ],
  "fuse": {
    "register": "SolidFuse"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json && bun scripts/post-build.ts"
  },
  "peerDependencies": {
    "@solidjs/universal": "^2.0.0-beta.4",
    "solid-js": "^2.0.0-beta.4"
  },
  "dependencies": {
    "citty": "^0.1.6"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vite-plugin-solid": "^3.0.0-next.3"
  }
}
